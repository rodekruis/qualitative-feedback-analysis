PATH_add .devcontainer/bin

dotenv_if_exists .env
dotenv_if_exists .devcontainer/.env

# Propagate host UID/GID into docker compose build args so the in-container
# `dev` user matches the host — keeps bind-mounted workspace files writable
# regardless of whether the host runs UID 1000, 501, or anything else.
# UID/GID are bash built-ins; they must be explicitly exported to reach
# child processes like `docker compose`.
export USER_UID="$(id -u)"
export USER_GID="$(id -g)"
