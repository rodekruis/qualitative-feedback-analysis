# ── Required ─────────────────────────────────────────────────────────
LLM_API_KEY=your-api-key-here
AUTH_API_KEYS_CONFIG_PATH=api_keys.json

# ── LLM ──────────────────────────────────────────────────────────────
# LLM_PROVIDER=openai            # openai | azure_openai
# LLM_MODEL=gpt-4o
# LLM_AZURE_ENDPOINT=
# LLM_API_VERSION=
# LLM_TIMEOUT_SECONDS=115.0
# LLM_MAX_RETRIES=3
# LLM_MAX_TOTAL_TOKENS=100000

# ── Orchestrator ─────────────────────────────────────────────────────
# ORCHESTRATOR_METADATA_FIELDS_TO_INCLUDE=[]
# ORCHESTRATOR_RETRY_BASE_SECONDS=1.0
# ORCHESTRATOR_RETRY_MULTIPLIER=2.0
# ORCHESTRATOR_RETRY_JITTER_FACTOR=0.5
# ORCHESTRATOR_RETRY_CAP_SECONDS=10.0
# ORCHESTRATOR_CHARS_PER_TOKEN=4

# ── Logging ──────────────────────────────────────────────────────────
# LOGLEVEL=DEBUG
# LOGLEVEL_3RDPARTY=WARNING


# -- Networking -------------------------------------------------------
# NETWORK_HOST=0.0.0.0
# NETWORK_PORT=8000
